# Copie ce fichier en ".env" et remplis tes vraies valeurs.
# Ne jamais commit le fichier .env (ajoute-le a .gitignore).

# Cle(s) API Groq (https://console.groq.com/keys)
# Tu peux mettre PLUSIEURS cles separees par des virgules pour eviter les quotas epuises :
# GROQ_API_KEY=cle1,cle2,cle3
GROQ_API_KEY=

# Cle API Tavily (gratuite sur https://tavily.com) pour activer la recherche web en temps reel.
# Optionnel : si absente, la recherche web est simplement desactivee.
TAVILY_API_KEY=

# Cle secrete Flask, pour signer les sessions. Genere une valeur aleatoire longue.
FLASK_SECRET_KEY=

# Hash sale (pbkdf2/hashlib) des codes d'acces (generes avec generate_codes.py, PAS le code en clair)
CID_CODE_HASH=
SAD_CODE_HASH=
